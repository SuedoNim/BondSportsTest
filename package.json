{
  "name": "bondsportstest",
  "version": "1.0.0",
  "description": "Emulate banking system",
  "main": "index.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "install:all": "npm install && npm run build && npm run seed",
    "install": "npm install",
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "seed": "ts-node src/seeds/seed.ts",
    "swagger": "echo 'Open http://localhost:3000/api/docs'",
    "docker:build": "docker build -t banking-api:latest .",
    "docker:run": "docker run -d --name banking-api -p 3000:3000 -v $(pwd)/data:/app/data banking-api:latest",
    "docker:stop": "docker stop banking-api && docker rm banking-api || true",
    "docker:logs": "docker logs -f banking-api",
    "compose:up": "docker-compose up -d",
    "compose:down": "docker-compose down",
    "clean": "rm -rf dist node_modules data coverage"
  },
  "keywords": [
    "BondSports"
  ],
  "author": "Daniel Kon",
  "license": "MIT",
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "awilix": "^13.0.3",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-swagger": "^5.1.1",
    "jest": "^30.3.0",
    "jsonwebtoken": "^9.0.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "typeorm": "^0.3.28",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
